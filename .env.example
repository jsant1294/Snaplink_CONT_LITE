# OpenRouter (free models only — enforced by lib/ai/model-guard.ts)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxx
# Optional override; MUST end in ":free" or the model guard will reject it
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Used for OpenRouter attribution headers
APP_URL=http://localhost:3000

# Operator master PIN (unlocks the operator console + every contractor scope)
OPERATOR_PIN=777777

# Production database (Neon Postgres connection string). When set, the app
# runs on Postgres via Drizzle. When unset, local JSON files (.data/) are used.
# DATABASE_URL=postgres://user:pass@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Optional: Vercel Blob for photo storage (recommended in production)
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxx

# Optional: instant SMS alert to the contractor when a new lead comes in.
# All three required to send; unset = feature silently no-ops.
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_FROM_NUMBER=+15555550100
